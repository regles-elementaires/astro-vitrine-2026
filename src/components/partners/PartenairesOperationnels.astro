---
import partnersData from "../../data/partenaires_operationnels.json";
---

<div>
    <div class="inline-block square-title mt-10 bg-remaroon text-rebeige-300 text-2xl">{partnersData.category}</div>
</div>

<div class="relative">
    <div class="overflow-hidden py-4 px-6"> 
        <div id="track-operationnels" class="flex transition-transform duration-500 ease-out">
        {
            partnersData.partners.map((partner) => (
                <div class="min-w-full md:min-w-1/5 p-4">
                    <div class="bg-white rounded-xl p-4 h-30 text-center flex items-center justify-center transition-all duration-300">
                        <img class="max-h-full w-auto" src={partner.image} alt={partner.name} />
                    </div>
                </div>
            ))
        }         
        </div>
    </div>

    <button id="prevBtn-operationnels" class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-2 md:-translate-x-6 bg-white p-2 md:p-3 rounded-full z-10 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </button>
    <button id="nextBtn-operationnels" class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-2 md:translate-x-6 bg-white p-2 md:p-3 rounded-full z-10 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </button>
</div>

<script>
    /* https://tailwindflex.com/@Starboy/our-services */

    document.addEventListener('DOMContentLoaded', () => {
        const track = document.getElementById('track-operationnels');
        const nextBtn = document.getElementById('nextBtn-operationnels');
        const prevBtn = document.getElementById('prevBtn-operationnels');
        
        let index = 0;
        const items = track!.children;
        const itemsPerView = window.innerWidth >= 768 ? 5 : 1;
        const maxIndex = items.length - itemsPerView;


        function updateCarousel() {
            track!.style.transform = `translateX(-${(index * 100) / itemsPerView}%)`;
        }

        function nextSlide() {
            index = index < maxIndex ? index + itemsPerView : 0;
            updateCarousel();
        }
        
        function prevSlide() {
            index = index > 0 ? index - itemsPerView : maxIndex;
            updateCarousel();
        }

        nextBtn!.addEventListener('click', () => { nextSlide(); });
        prevBtn!.addEventListener('click', () => { prevSlide(); });
        
    });
</script>