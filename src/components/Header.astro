---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import RedLogo from '../assets/LOGOTYPE-RE-HORIZONTAL-ROUGE.svg';
import WhiteLogo from '../assets/LOGOTYPE-RE-HORIZONTAL-BLANC.svg';
---

<header class="">
  <nav>
    <div class="wrapper">
      <div class="nav-column first-nav-column">
        <div class="logo">
          <a href="/">
            <Image id="red-logo" src={RedLogo} alt="Règles élémentaires" />
            <Image id="white-logo" src={WhiteLogo} alt="Règles élémentaires" />
          </a>
        </div>
        <input type="checkbox" name="menu" id="menu-btn">
        <label for="menu-btn" class="btn menu-btn">Menu</label>
      </div>
      <div class="nav-column second-nav-column"></div>
      <div class="nav-column third-nav-column">
        <div class="nav-right-buttons">
          <a class="square-button font-semibold bg-black text-white" href="/">Faire un don</a>
        </div>        
      </div>
    </div>
    <div id="mega-box">
        <div class="content">
          <div class="nav-column bg-rered">
            <ul class="mega-links">
              <li><a href="#">Qui sommes-nous ?</a></li>
              <li><a id="nos-actions-link" href="#">Nos actions</a></li>
              <li><a href="#">Notre impact</a></li>
            </ul>
          </div>
          <div class="nav-column actu-column bg-regreen">
            <ul id="mega-nos-actions-submenu">
              <li><a href="/about">Lutter contre la précarité menstruelle</a></li>
              <li><a href="#">Déployer l'éducation menstruelle</a></li>
              <li><a href="#">Informer</a></li>
              <li><a href="#">Former</a></li>
              <li><a href="#">Mobiliser</a></li>
            </ul>
          </div>
          <div class="nav-column bg-reyellow">
          </div>
        </div>
      </div>
  </nav>
</header>