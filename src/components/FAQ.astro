        </div>
        <div class="faq-item flex flex-col items-start w-full" data-index="${index}">
            <div class="faq-header flex items-center w-full cursor-pointer border-b p-4 transition-all">
                <svg class="faq-icon transition-all duration-300" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="m4.5 7.2 3.793 3.793a1 1 0 0 0 1.414 0L13.5 7.2" stroke="#1D293D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
