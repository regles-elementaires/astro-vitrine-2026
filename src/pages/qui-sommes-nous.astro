<script>
    document.querySelectorAll('.antenne').forEach((antenne) => {
        antenne.addEventListener('click', () => {                    
            antenne.classList.remove('text-rebeige-500');                                
            antenne.classList.remove('cursor-pointer');                                
            antenne.classList.add('bg-none-important');  
            antenne.querySelector('.antenne-content')!.classList.add('opacity-100');
            antenne.querySelector('.antenne-content')!.classList.add('max-h-[800px]');
            antenne.querySelector('.antenne-content')!.classList.add('translate-y-0');
            antenne.querySelector('.antenne-content')!.classList.add('pt-10');
            antenne.querySelector('.antenne-content')!.classList.remove('max-h-0');
            antenne.querySelector('.antenne-content')!.classList.remove('-translate-y-2');                                                             
        });
    });
</script>